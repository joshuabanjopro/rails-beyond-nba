<h1>Add your favourite club to our growing database</h1>

<%= form_with model:@club do |f| %>
    <%= f.label :name %>
    <%= f.text_field :name %>
    <%= f.label :location %>
    <%= f.text_field :location %>
    <%= f.label :championships %>
    <%= f.number_field :championships %>
    <%= f.submit %>
<% end %>