<h1>Use the Form below to change some of the data for this club :D</h1>

<%= form_with model: @club do |f| %>
    <%= f.label :name %>
    <%= f.text_field :name %>
    <%= f.label :location %>
    <%= f.text_field :location %>
    <%= f.label :championships %>
    <%= f.text_field :championships %>
    <%= f.submit %>
<% end %>